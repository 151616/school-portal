{
  "rules": {
    "Users": {
      // Admins can list/read all users at /Users; individual users can read their own record via $uid
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && (auth.token.admin === true || auth.uid === $uid)",
      ".indexOn": ["email"],
      "$uid": {
        ".read": "auth != null && (auth.token.admin === true || auth.uid === $uid)",
        ".validate": "newData.hasChildren(['email','role']) && newData.child('email').isString() && newData.child('role').isString()"
      }
    },
    "grades": {
      "$studentUid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.token.admin === true || auth.uid === $studentUid)"
      }
    },
    "invites": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true",
      "$inviteId": {
        ".validate": "newData.hasChildren(['email','role','studentId','createdAt','used','createdBy']) && newData.child('email').isString() && newData.child('email').val().matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$') && newData.child('role').isString() && newData.child('studentId').isString() && newData.child('createdBy').isString() && newData.child('used').isBoolean()"
      }
    }
  }
}
